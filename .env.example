# ============================
# Database Configuration
# ============================

# Connection string for your PostgreSQL database.
# Format: postgresql://<username>:<password>@<host>:<port>/<database>
DATABASE_URL="your-database-url-here"

# ============================
# Application URL
# ============================

# Publicly accessible URL of your Next.js app.
# Used for client-side requests and redirects.
NEXT_PUBLIC_APP_URL="your-app-url-here"

# ============================
# Better Auth Configuration
# ============================

# Secret key for authentication.
# Must be a randomly generated string with at least 32 characters.
BETTER_AUTH_SECRET="your-32+-char-random-secret-here"

# Base URL of your app for authentication callbacks.
# Typically matches NEXT_PUBLIC_APP_URL.
BETTER_AUTH_URL="your-auth-url-here"
